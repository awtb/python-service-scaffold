.PHONY: install run test{% if include_pre_commit %} hooks pre-commit{% endif %}

install:
	uv sync --extra dev

run: install
{% if include_http_runtime %}
	uv run python -m {{ package_name }} http --reload
{% else %}
	uv run python -m {{ package_name }}
{% endif %}

test: install
	uv run pytest
{% if include_pre_commit %}

hooks: install
	uv run pre-commit install

pre-commit: install
	uv run pre-commit run --all-files
{% endif %}
