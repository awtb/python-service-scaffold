.PHONY: install run{% if include_tests %} test{% endif %}{% if include_pre_commit %} hooks pre-commit{% endif %}

install:
	uv sync --extra dev

run: install
{% if include_http_runtime %}
	uv run python -m {{ package_name }} http --reload
{% elif include_stream_runtime and include_redis_plugin %}
	uv run python -m {{ package_name }} stream
{% else %}
	uv run python -m {{ package_name }}
{% endif %}

{% if include_tests %}
test: install
	uv run pytest
{% endif %}
{% if include_pre_commit %}

hooks: install
	uv run pre-commit install

pre-commit: install
	uv run pre-commit run --all-files
{% endif %}
