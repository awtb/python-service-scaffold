from {{ package_name }}.settings import Settings
from {{ package_name }}.settings import get_settings


def create_redis_client(settings: Settings | None = None) -> RedisClient:
    current_settings = settings or get_settings()
    return Redis.from_url(current_settings.redis_url, decode_responses=True)
