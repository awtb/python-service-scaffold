from uuid import UUID

from fastapi import APIRouter
from fastapi import Depends
from fastapi import HTTPException
from fastapi import status
from fastapi.security import OAuth2PasswordRequestForm

from {{ package_name }}.features.users.contracts import AuthenticateUserCommand
from {{ package_name }}.features.users.exceptions import AuthenticationError
from {{ package_name }}.features.users.contracts import GetUserCommand
from {{ package_name }}.features.users.contracts import ListUsersCommand
from {{ package_name }}.features.users.models import User
from {{ package_name }}.features.users.use_cases import AuthenticateUserUseCase
from {{ package_name }}.features.users.use_cases import GetUserUseCase
from {{ package_name }}.features.users.use_cases import ListUsersUseCase
from {{ package_name }}.runtimes.http.dependencies import get_authenticate_user_use_case
from {{ package_name }}.runtimes.http.dependencies import get_current_user
from {{ package_name }}.runtimes.http.dependencies import get_get_user_use_case
from {{ package_name }}.runtimes.http.dependencies import get_list_users_use_case
from {{ package_name }}.runtimes.http.dependencies import get_pagination_params
from {{ package_name }}.runtimes.http.dependencies import PaginationParams
from {{ package_name }}.runtimes.http.schemas import AccessTokenResponse
from {{ package_name }}.runtimes.http.schemas import PageResponse
from {{ package_name }}.runtimes.http.schemas import UserResponse

router = APIRouter()


@router.post("/auth/token", response_model=AccessTokenResponse, tags=["Auth"])
async def login_for_access_token(
    form_data: OAuth2PasswordRequestForm = Depends(),
    use_case: AuthenticateUserUseCase = Depends(get_authenticate_user_use_case),
) -> AccessTokenResponse:
    try:
        return await use_case.execute(
            AuthenticateUserCommand(
                email=form_data.username,
                password=form_data.password,
            ),
        )
    except AuthenticationError as exc:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail=str(exc),
            headers={"WWW-Authenticate": "Bearer"},
        ) from exc


@router.get("/users/me", response_model=UserResponse, tags=["Users"])
async def get_current_authenticated_user(
    current_user: User = Depends(get_current_user),
) -> UserResponse:
    return current_user


@router.get("/users", response_model=PageResponse[User], tags=["Users"])
async def list_users(
    pagination: PaginationParams = Depends(get_pagination_params),
    _current_user: User = Depends(get_current_user),
    use_case: ListUsersUseCase = Depends(get_list_users_use_case),
) -> PageResponse[User]:
    users_page = await use_case.execute(
        ListUsersCommand(
            page=pagination.page,
            page_size=pagination.page_size,
        )
    )

    return users_page


@router.get("/users/{user_id}", response_model=UserResponse, tags=["Users"])
async def get_user(
    user_id: UUID,
    _current_user: User = Depends(get_current_user),
    use_case: GetUserUseCase = Depends(get_get_user_use_case),
) -> UserResponse:
    user = await use_case.execute(GetUserCommand(user_id=user_id))

    if user is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="User not found.",
        )

    return user
