import base64
import hashlib
import hmac
import secrets

PBKDF2_ALGORITHM = "pbkdf2_sha256"
PBKDF2_ITERATIONS = 600_000
SALT_BYTES = 16


class Pbkdf2PasswordService:
    def hash(self, password: str) -> str:
        salt = secrets.token_bytes(SALT_BYTES)
        password_bytes = password.encode("utf-8")
        password_hash = hashlib.pbkdf2_hmac(
            "sha256",
            password_bytes,
            salt,
            PBKDF2_ITERATIONS,
        )
        encoded_salt = base64.b64encode(salt).decode("ascii")
        encoded_hash = base64.b64encode(password_hash).decode("ascii")
        return (
            f"{PBKDF2_ALGORITHM}${PBKDF2_ITERATIONS}${encoded_salt}${encoded_hash}"
        )

    def verify(self, password: str, password_hash: str) -> bool:
        try:
            algorithm, iterations, encoded_salt, encoded_hash = password_hash.split(
                "$",
                maxsplit=3,
            )
        except ValueError:
            return False

        if algorithm != PBKDF2_ALGORITHM:
            return False

        try:
            salt = base64.b64decode(encoded_salt.encode("ascii"))
            expected_hash = base64.b64decode(encoded_hash.encode("ascii"))
            iterations_count = int(iterations)
        except (ValueError, TypeError):
            return False

        actual_hash = hashlib.pbkdf2_hmac(
            "sha256",
            password.encode("utf-8"),
            salt,
            iterations_count,
        )
        return hmac.compare_digest(actual_hash, expected_hash)
