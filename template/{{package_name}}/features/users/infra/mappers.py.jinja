from {{ package_name }}.infra.db.models.user import UserRecord
from {{ package_name }}.models.user import User
from {{ package_name }}.models.user import UserCredentials


def to_user_model(record: UserRecord) -> User:
    return User(
        id=record.id,
        email=record.email,
        full_name=record.full_name,
        is_active=record.is_active,
        created_at=record.created_at,
    )


def to_user_credentials(record: UserRecord) -> UserCredentials:
    return UserCredentials(
        user=to_user_model(record),
        password_hash=record.password_hash,
    )
