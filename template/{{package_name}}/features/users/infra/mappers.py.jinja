from {{ package_name }}.infra.db.models.user import UserRecord
from {{ package_name }}.features.users.dto import UserCredentialsDTO
from {{ package_name }}.features.users.dto import UserDTO


def to_user_dto(record: UserRecord) -> UserDTO:
    return UserDTO(
        id=record.id,
        email=record.email,
        full_name=record.full_name,
        is_active=record.is_active,
        created_at=record.created_at,
    )


def to_user_credentials_dto(record: UserRecord) -> UserCredentialsDTO:
    return UserCredentialsDTO(
        user=to_user_dto(record),
        password_hash=record.password_hash,
    )
