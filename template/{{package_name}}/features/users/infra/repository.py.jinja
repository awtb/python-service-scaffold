from uuid import UUID

from sqlalchemy import select

from {{ package_name }}.features.users.ports import UsersRepository
from {{ package_name }}.infra.db import BaseRepository
from {{ package_name }}.infra.db.models.users import UserRecord
from {{ package_name }}.models.page_result import PageResult
from {{ package_name }}.models.user import User
from {{ package_name }}.protocols import UnitOfWork

from .mappers import create_user_record
from .mappers import to_user_model


def build_users_repository(uow: UnitOfWork) -> UsersRepository:
    return SqlAlchemyUsersRepository.from_uow(uow)


class SqlAlchemyUsersRepository(BaseRepository[User], UsersRepository):
    async def create(self, email: str, full_name: str) -> User:
        record = create_user_record(
            email=email,
            full_name=full_name,
        )
        self._session.add(record)
        await self._session.flush()
        return to_user_model(record)

    async def get_by_email(self, email: str) -> User | None:
        record = await self._session.scalar(
            select(UserRecord).where(UserRecord.email == email)
        )
        if record is None:
            return None
        return to_user_model(record)

    async def get_by_id(self, user_id: UUID) -> User | None:
        record = await self._session.get(UserRecord, user_id)
        if record is None:
            return None
        return to_user_model(record)

    async def list(self, page: int, page_size: int) -> PageResult[User]:
        query = select(UserRecord).order_by(UserRecord.created_at.desc())
        return await self._fetch(query, page, page_size, to_user_model)
