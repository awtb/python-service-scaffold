from fastapi.testclient import TestClient

from {{ package_name }}.runtimes.http.app import build_app

def test_healthcheck({% if include_tg_bot_runtime and include_http_runtime %}monkeypatch{% endif %}) -> None:
{% if include_tg_bot_runtime and include_http_runtime %}
    monkeypatch.setenv("APP_TELEGRAM_WEBHOOK_URL", "https://example.com/telegram")
{% endif %}
    client = TestClient(build_app())

    response = client.get("/internal/healthcheck")

    assert response.status_code == 200
    assert response.json() == {"status": "ok"}
    assert "X-Request-ID" in response.headers


def test_metrics_endpoint({% if include_tg_bot_runtime and include_http_runtime %}monkeypatch{% endif %}) -> None:
{% if include_tg_bot_runtime and include_http_runtime %}
    monkeypatch.setenv("APP_TELEGRAM_WEBHOOK_URL", "https://example.com/telegram")
{% endif %}
    client = TestClient(build_app())

    healthcheck_response = client.get("/internal/healthcheck")
    metrics_response = client.get("/internal/metrics")

    assert healthcheck_response.status_code == 200
    assert metrics_response.status_code == 200
    assert "http_requests_total" in metrics_response.text
    assert "http_request_duration_seconds" in metrics_response.text
    assert 'route="/internal/healthcheck"' in metrics_response.text
    assert 'method="GET"' in metrics_response.text
    assert 'status_class="2xx"' in metrics_response.text


def test_cors_preflight({% if include_tg_bot_runtime and include_http_runtime %}monkeypatch{% endif %}) -> None:
{% if include_tg_bot_runtime and include_http_runtime %}
    monkeypatch.setenv("APP_TELEGRAM_WEBHOOK_URL", "https://example.com/telegram")
{% endif %}
    client = TestClient(build_app())

    response = client.options(
        "/internal/healthcheck",
        headers={
            "Origin": "https://example.com",
            "Access-Control-Request-Method": "GET",
        },
    )

    assert response.status_code == 200
    assert response.headers["access-control-allow-origin"] == "*"
