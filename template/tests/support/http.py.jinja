    monkeypatch.setenv("APP_JWT_SECRET_KEY", "test-secret-key-with-32-bytes-minimum")
    monkeypatch.setenv("APP_JWT_ACCESS_TOKEN_EXPIRE_MINUTES", "30")
{% endif %}
{% endif %}
{% if not include_tg_bot_runtime and not include_postgresql_integration %}
    pass
