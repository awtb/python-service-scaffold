services:
  app:
    build:
      context: .
    command: ["python", "-m", "{{ package_name }}"{% if include_http_runtime %}, "http"{% endif %}]
{% if include_postgresql_plugin %}
    depends_on:
      - db
    environment:
      APP_DB_HOST: db
      APP_DB_PORT: "5432"
      APP_DB_NAME: app
      APP_DB_USER: app
      APP_DB_PASSWORD: app
{% endif %}
{% if include_http_runtime %}
    ports:
      - "8000:8000"
{% endif %}
{% if include_postgresql_plugin %}
  db:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: app
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

volumes:
  postgres_data:
{% endif %}
