{% set has_stream_runtime = include_stream_runtime and include_redis_plugin %}
{% set primary_runtime = "http" if include_http_runtime else "stream" if has_stream_runtime else none %}
services:
  app:
    build:
      context: .
    command: ["python", "-m", "{{ package_name }}"{% if primary_runtime %}, "{{ primary_runtime }}"{% endif %}]
{% if include_postgresql_plugin or include_redis_plugin %}
    depends_on:
{% if include_postgresql_plugin %}
      - db
{% endif %}
{% if include_redis_plugin %}
      - redis
{% endif %}
    environment:
{% if include_postgresql_plugin %}
      APP_DB_HOST: db
      APP_DB_PORT: "5432"
      APP_DB_NAME: app
      APP_DB_USER: app
      APP_DB_PASSWORD: app
{% endif %}
{% if include_redis_plugin %}
      APP_REDIS_URL: redis://redis:6379/0
{% endif %}
{% endif %}
{% if include_http_runtime %}
    ports:
      - "8000:8000"
{% endif %}
{% if has_stream_runtime and primary_runtime != "stream" %}
  stream:
    build:
      context: .
    command: ["python", "-m", "{{ package_name }}", "stream"]
{% if include_postgresql_plugin or include_redis_plugin %}
    depends_on:
{% if include_postgresql_plugin %}
      - db
{% endif %}
{% if include_redis_plugin %}
      - redis
{% endif %}
    environment:
{% if include_postgresql_plugin %}
      APP_DB_HOST: db
      APP_DB_PORT: "5432"
      APP_DB_NAME: app
      APP_DB_USER: app
      APP_DB_PASSWORD: app
{% endif %}
{% if include_redis_plugin %}
      APP_REDIS_URL: redis://redis:6379/0
{% endif %}
{% endif %}
{% endif %}
{% if include_postgresql_plugin %}
  db:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: app
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

volumes:
  postgres_data:
{% endif %}
{% if include_redis_plugin %}
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
{% endif %}
